# Jina AI — get a free API key at https://jina.ai
JINA_API_KEY=jina_...

# ---------------------------------------------------------------------------
# Elasticsearch — pick ONE deployment. Switching later is safe: the app
# detects the new cluster and re-indexes from its embed cache (no extra
# embedding API calls). See "Choosing an Elasticsearch deployment" in the
# README.
# ---------------------------------------------------------------------------

# Option 1 — Local Docker (docker compose up -d elasticsearch). No key needed.
ES_URL=http://localhost:9200
ES_API_KEY=

# Option 2 — Elastic Cloud (managed deployment).
# Use the endpoint URL from your deployment page + an API key:
#ES_URL=https://my-deployment.es.us-west1.gcp.cloud.es.io:443
#ES_API_KEY=...
# ...or the deployment's Cloud ID instead of the URL:
#ES_CLOUD_ID=my-deployment:dXMtd2VzdDEuZ2NwLi4u
#ES_API_KEY=...

# Option 3 — Elastic Cloud Serverless.
# Use the project endpoint URL + an API key (both from the project overview):
#ES_URL=https://my-project-abc123.es.us-east-1.aws.elastic.cloud:443
#ES_API_KEY=...

# Pexels — only needed to run scripts/download_pexels.py
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional overrides
# WATCH_DIR=./clips          # initial library folder (UI can change this)
# CHUNKS_DIR=./chunks        # app-owned scene chunks + manifests
# BROLL_INDEX=broll
